{
  "name": "@gustavoadolfo/minhoteca-adapter-layer",
  "version": "0.0.0",
  "description": "Camada de adaptadores, repositórios, proxies e outros padrões para solução de demandas do projeto Minhoteca.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cd layer/nodejs && tsc && tsc-alias",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint layer/nodejs/src tests --ext .ts",
    "lint:fix": "eslint layer/nodejs/src tests --ext .ts --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{js,ts,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,md,json,yml,yaml}\"",
    "clean": "rm -rf dist coverage",
    "postinstall": "husky install"
  },
  "keywords": [
    "minhoteca",
    "biblioteca",
    "comunidade"
  ],
  "author": "Gustavo Adolfo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GustavoAdolfo/minhoteca-adapter-layer.git"
  },
  "bugs": {
    "url": "https://github.com/GustavoAdolfo/minhoteca-adapter-layer/issues"
  },
  "homepage": "https://github.com/GustavoAdolfo/minhoteca-adapter-layer#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{layer/nodejs/src,tests}/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1048.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/lib-dynamodb": "^3.1048.0",
    "@aws-sdk/node-http-handler": "^3.370.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@gustavoadolfo/minhoteca-core-layer": "^1.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "commitlint": "^21.0.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
