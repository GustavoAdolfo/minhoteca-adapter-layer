{
  "name": "@gustavoadolfo/minhoteca-adapter-layer",
  "version": "0.1.23",
  "description": "Camada de adaptadores, repositórios, proxies e outros padrões para solução de demandas do projeto Minhoteca.",
  "main": "layer/nodejs/dist/index.js",
  "types": "layer/nodejs/dist/index.d.ts",
  "files": [
    "layer/nodejs/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cd layer/nodejs && tsc && tsc-alias",
    "prepack": "npm run build",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:all": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --watch",
    "lint": "eslint layer/nodejs/src tests --ext .ts",
    "lint:fix": "eslint layer/nodejs/src tests --ext .ts --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{js,ts,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,md,json,yml,yaml}\"",
    "clean": "rm -rf layer/nodejs/dist coverage",
    "prepare": "husky"
  },
  "keywords": [
    "minhoteca",
    "biblioteca",
    "comunidade"
  ],
  "author": "Gustavo Adolfo",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gustavoadolfo/minhoteca-adapter-layer.git"
  },
  "bugs": {
    "url": "https://github.com/gustavoadolfo/minhoteca-adapter-layer/issues"
  },
  "homepage": "https://github.com/gustavoadolfo/minhoteca-adapter-layer#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{layer/nodejs/src,tests}/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "dependencies": {
    "mongodb": "^7.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-dynamodb": "^3.1073.0",
    "@aws-sdk/node-http-handler": "^3.374.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@gustavoadolfo/minhoteca-core-layer": "^1.0.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.59.4",
    "commitlint": "^21.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
